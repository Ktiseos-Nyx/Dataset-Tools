{
  "parser_name": "Draw Things (XMP JSON)",
  "priority": 95,
  "target_file_types": [
    "PNG",
    "JPEG",
    "WEBP",
    "TIFF"
  ],
  "detection_rules": [
    {
      "comment": "Rule 1: XMP string must exist in the context data.",
      "source_type": "xmp_string_content",
      "operator": "exists"
    },
    {
      "comment": "Rule 2: The XMP string must contain an exif:UserComment that is valid JSON.",
      "source_type": "xmp_exif_user_comment_content",
      "operator": "is_valid_json"
    },
    {
      "comment": "Rule 3: The JSON from exif:UserComment must contain characteristic Draw Things keys.",
      "source_type": "json_from_xmp_exif_user_comment",
      "operator": "json_contains_all_keys",
      "expected_keys": [
        "c",
        "sampler"
      ]
    }
  ],
  "parsing_instructions": {
    "input_data": {
      "comment": "Engine extracts the string content of XMP's exif:UserComment.",
      "source_type": "xmp_exif_user_comment_content_string",
      "transformations": [
        {
          "type": "json_decode_string_itself",
          "comment": "Parse the exif:UserComment string into a JSON object."
        }
      ]
    },
    "fields": [
      {
        "target_key": "prompt",
        "method": "direct_json_path",
        "json_path": "c",
        "value_type": "string"
      },
      {
        "target_key": "negative_prompt",
        "method": "direct_json_path",
        "json_path": "uc",
        "value_type": "string",
        "optional": true
      },
      {
        "target_key": "parameters.model",
        "method": "direct_json_path",
        "json_path": "model",
        "value_type": "string",
        "optional": true
      },
      {
        "target_key": "parameters.sampler_name",
        "method": "direct_json_path",
        "json_path": "sampler",
        "value_type": "string"
      },
      {
        "target_key": "parameters.seed",
        "method": "direct_json_path",
        "json_path": "seed",
        "value_type": "integer_or_string"
      },
      {
        "target_key": "parameters.cfg_scale",
        "method": "direct_json_path",
        "json_path": "scale",
        "value_type": "float_or_integer"
      },
      {
        "target_key": "parameters.steps",
        "method": "direct_json_path",
        "json_path": "steps",
        "value_type": "integer"
      },
      {
        "target_key": "_internal.size_str",
        "method": "direct_json_path",
        "json_path": "size",
        "value_type": "string",
        "optional": true
      },
      {
        "target_key": "parameters.width",
        "method": "regex_transform_from_variable",
        "source_variable_key": "_internal.size_str_VAR_",
        "transform_regex": "^(\\d+)x\\d+$",
        "transform_group": 1,
        "value_type": "integer",
        "optional": true
      },
      {
        "target_key": "parameters.height",
        "method": "regex_transform_from_variable",
        "source_variable_key": "_internal.size_str_VAR_",
        "transform_regex": "^\\d+x(\\d+)$",
        "transform_group": 1,
        "value_type": "integer",
        "optional": true
      }
    ],
    "output_template": {
      "parser_name_from_engine": "Draw Things (XMP JSON)",
      "tool": "Draw Things",
      "prompt": "$prompt",
      "negative_prompt": "$negative_prompt",
      "parameters": {
        "model": "$parameters.model",
        "sampler_name": "$parameters.sampler_name",
        "seed": "$parameters.seed",
        "cfg_scale": "$parameters.cfg_scale",
        "steps": "$parameters.steps",
        "width": "$CONTEXT.width",
        "height": "$CONTEXT.height"
      },
      "tool_specific_parameters_json": {
        "method": "collect_remaining_json_fields",
        "exclude_paths": [
          "c",
          "uc",
          "model",
          "sampler",
          "seed",
          "scale",
          "steps",
          "size"
        ]
      },
      "workflow": "$INPUT_JSON_OBJECT_AS_STRING"
    }
  }
}
