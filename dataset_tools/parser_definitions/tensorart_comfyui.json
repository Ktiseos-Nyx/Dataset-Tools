{
  "parser_name": "TensorArt ComfyUI",
  "priority": 145,
  "target_file_types": [
    "PNG"
  ],
  "detection_rules": [
    {
      "comment": "Rule 1: Workflow/Prompt chunk contains JSON.",
      "condition": "OR",
      "rules": [
        {
          "source_type": "pil_info_key",
          "source_key": "workflow",
          "operator": "is_valid_json"
        },
        {
          "source_type": "pil_info_key",
          "source_key": "prompt",
          "operator": "is_valid_json"
        }
      ]
    },
    {
      "comment": "Rule 2: Presence of TensorArt specific or commonly used node types OR EMS pattern in model/LoRA names.",
      "condition": "OR",
      "rules": [
        {
          "comment": "Sub-Rule 2a: Check for specific node types.",
          "source_type": "pil_info_key_json_path_query",
          "source_key_options": [
            "workflow",
            "prompt"
          ],
          "json_query_type": "has_any_node_class_type",
          "class_types_to_check": [
            "ECHOCheckpointLoaderSimple",
            "LoraTagLoader",
            "BNK_CLIPTextEncodeAdvanced",
            "KSampler_A1111",
            "YoloDetectorProvider"
          ],
          "operator": "is_true"
        },
        {
          "comment": "Sub-Rule 2b: Check for 'EMS-xxxxxx-EMS.safetensors' pattern in the raw JSON content.",
          "source_type": "pil_info_key_json_content_regex",
          "source_key_options": [
            "workflow",
            "prompt"
          ],
          "regex_pattern": "EMS-\\d+-EMS\\.safetensors",
          "operator": "exists"
        }
      ]
    },
    {
      "comment": "Rule 3: Ensure it's not a Civitai ComfyUI with extraMetadata (to avoid conflict with higher priority parser).",
      "source_type": "pil_info_key_json_path_string_is_json",
      "source_key_options": [
        "workflow",
        "prompt"
      ],
      "json_path": "extra.extraMetadata",
      "operator": "not_exists_or_not_valid_json"
    }
  ],
  "parsing_instructions": {
    "input_data": {
      "source_options": [
        {
          "source_type": "pil_info_key",
          "source_key": "workflow"
        },
        {
          "source_type": "pil_info_key",
          "source_key": "prompt"
        }
      ],
      "transformations": [
        {
          "type": "json_decode_string_itself"
        }
      ]
    },
    "fields": [
      {
        "target_key": "prompt",
        "method": "comfy_find_text_from_main_sampler_input",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "positive_input_name": "positive",
        "text_input_name_in_encoder": "text",
        "text_encoder_node_types": [
          "BNK_CLIPTextEncodeAdvanced",
          "CLIPTextEncode"
        ]
      },
      {
        "target_key": "negative_prompt",
        "method": "comfy_find_text_from_main_sampler_input",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "negative_input_name": "negative",
        "text_input_name_in_encoder": "text",
        "text_encoder_node_types": [
          "BNK_CLIPTextEncodeAdvanced",
          "CLIPTextEncode"
        ]
      },
      {
        "target_key": "parameters.seed",
        "method": "comfy_find_input_of_main_sampler",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "input_key": "seed",
        "value_type": "integer"
      },
      {
        "target_key": "parameters.steps",
        "method": "comfy_find_input_of_main_sampler",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "input_key": "steps",
        "value_type": "integer"
      },
      {
        "target_key": "parameters.cfg_scale",
        "method": "comfy_find_input_of_main_sampler",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "input_key": "cfg",
        "value_type": "float"
      },
      {
        "target_key": "parameters.sampler_name",
        "method": "comfy_find_input_of_main_sampler",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "input_key": "sampler_name",
        "value_type": "string"
      },
      {
        "target_key": "parameters.scheduler",
        "method": "comfy_find_input_of_main_sampler",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "input_key": "scheduler",
        "value_type": "string",
        "optional": true
      },
      {
        "target_key": "parameters.denoise",
        "method": "comfy_find_input_of_main_sampler",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "input_key": "denoise",
        "value_type": "float",
        "optional": true
      },
      {
        "target_key": "parameters.model",
        "method": "comfy_find_node_input",
        "node_criteria": [
          {
            "class_type": "ECHOCheckpointLoaderSimple"
          }
        ],
        "input_key": "ckpt_name",
        "value_type": "string"
      },
      {
        "target_key": "parameters.vae_model",
        "method": "static_value",
        "value": null,
        "optional": true
      },
      {
        "target_key": "parameters.width",
        "method": "comfy_find_node_input",
        "node_criteria": [
          {
            "class_type": "EmptyLatentImage",
            "is_main_latent": true
          }
        ],
        "input_key": "width",
        "value_type": "integer",
        "optional": true
      },
      {
        "target_key": "parameters.height",
        "method": "comfy_find_node_input",
        "node_criteria": [
          {
            "class_type": "EmptyLatentImage",
            "is_main_latent": true
          }
        ],
        "input_key": "height",
        "value_type": "integer",
        "optional": true
      },
      {
        "target_key": "parameters.loras",
        "method": "comfy_extract_loras_from_linked_loaders",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "model_input_name_in_sampler": "model",
        "lora_loader_node_types": [
          "LoraTagLoader",
          "LoraLoader"
        ],
        "lora_text_input_key_in_loader": "text",
        "lora_name_input_key_in_loader": "lora_name"
      },
      {
        "target_key": "parameters.tool_specific.adetailer_denoise",
        "method": "comfy_find_input_of_secondary_sampler",
        "sampler_node_types": [
          "KSampler_A1111",
          "KSampler"
        ],
        "secondary_sampler_indicator_input_type": "InpaintModelConditioning",
        "input_key": "denoise",
        "value_type": "float",
        "optional": true
      }
    ],
    "output_template": {
      "parser_name_from_engine": "TensorArt ComfyUI",
      "tool": "TensorArt ComfyUI",
      "prompt": "$prompt",
      "negative_prompt": "$negative_prompt",
      "parameters": {
        "steps": "$parameters.steps",
        "sampler_name": "$parameters.sampler_name",
        "cfg_scale": "$parameters.cfg_scale",
        "seed": "$parameters.seed",
        "width": "$CONTEXT.width",
        "height": "$CONTEXT.height",
        "denoise": "$parameters.denoise",
        "model": "$parameters.model",
        "vae_model": "$parameters.vae_model",
        "loras": "$parameters.loras",
        "tool_specific": {
          "scheduler": "$parameters.scheduler",
          "adetailer_denoise_strength": "$parameters.tool_specific.adetailer_denoise"
        }
      },
      "workflow": "$INPUT_JSON_OBJECT_AS_STRING"
    }
  }
}
