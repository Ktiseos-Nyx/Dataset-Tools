{
  "parser_name": "StableSwarmUI",
  "priority": 108,
  "target_file_types": [
    "PNG",
    "JPEG",
    "WEBP"
  ],
  "detection_rules": [
    {
      "comment": "Rule 1: Must find JSON in 'parameters' PNG chunk or EXIF UserComment.",
      "condition": "OR",
      "rules": [
        {
          "source_type": "png_chunk",
          "source_key": "parameters",
          "operator": "is_valid_json"
        },
        {
          "source_type": "exif_user_comment",
          "operator": "is_valid_json"
        }
      ]
    },
    {
      "comment": "Rule 2: The parsed JSON (outer or inner) must contain 'sui_image_params' OR core SwarmUI keys directly.",
      "source_type": "json_from_usercomment_or_png_chunk",
      "chunk_source_key_options": [
        "parameters"
      ],
      "operator": "json_path_exists_or_contains_keys",
      "json_path_to_check_first": "sui_image_params",
      "fallback_keys_to_check_at_root": [
        "prompt",
        "seed",
        "model",
        "steps",
        "cfgscale"
      ]
    }
  ],
  "parsing_instructions": {
    "input_data": {
      "comment": "Engine gets JSON string from 'parameters' chunk or UserComment.",
      "source_options": [
        {
          "source_type": "pil_info_key",
          "source_key": "parameters"
        },
        {
          "source_type": "exif_user_comment"
        }
      ],
      "transformations": [
        {
          "type": "json_decode_string_itself",
          "comment": "1. Parse the initial string (from chunk/UserComment) into an outer JSON object."
        },
        {
          "type": "conditional_json_extract_nested_object",
          "comment": "2. If 'sui_image_params' key exists in outer JSON, use its value (which is an object). Else, use the outer JSON object itself.",
          "path_to_nested_object": "sui_image_params"
        }
      ]
    },
    "fields": [
      {
        "target_key": "prompt",
        "method": "direct_json_path",
        "json_path": "prompt",
        "value_type": "string"
      },
      {
        "target_key": "negative_prompt",
        "method": "direct_json_path",
        "json_path": "negativeprompt",
        "value_type": "string",
        "optional": true
      },
      {
        "target_key": "parameters.model",
        "method": "direct_json_path",
        "json_path": "model",
        "value_type": "string",
        "optional": true
      },
      {
        "target_key": "parameters.seed",
        "method": "direct_json_path",
        "json_path": "seed",
        "value_type": "integer_or_string"
      },
      {
        "target_key": "parameters.cfg_scale",
        "method": "direct_json_path",
        "json_path": "cfgscale",
        "value_type": "float_or_integer"
      },
      {
        "target_key": "parameters.steps",
        "method": "direct_json_path",
        "json_path": "steps",
        "value_type": "integer"
      },
      {
        "target_key": "parameters.sampler_name",
        "method": "direct_json_path_coalesce",
        "json_paths": [
          "comfyuisampler",
          "autowebuisampler"
        ],
        "value_type": "string",
        "optional": true
      },
      {
        "target_key": "parameters.width",
        "method": "direct_json_path",
        "json_path": "width",
        "value_type": "integer",
        "optional": true
      },
      {
        "target_key": "parameters.height",
        "method": "direct_json_path",
        "json_path": "height",
        "value_type": "integer",
        "optional": true
      }
    ],
    "output_template": {
      "parser_name_from_engine": "StableSwarmUI",
      "tool": "StableSwarmUI",
      "prompt": "$prompt",
      "negative_prompt": "$negative_prompt",
      "parameters": {
        "model": "$parameters.model",
        "seed": "$parameters.seed",
        "cfg_scale": "$parameters.cfg_scale",
        "steps": "$parameters.steps",
        "sampler_name": "$parameters.sampler_name",
        "width": "$CONTEXT.width",
        "height": "$CONTEXT.height"
      },
      "tool_specific_parameters_json": {
        "method": "collect_remaining_json_fields",
        "exclude_paths": [
          "prompt",
          "negativeprompt",
          "model",
          "seed",
          "cfgscale",
          "steps",
          "comfyuisampler",
          "autowebuisampler",
          "width",
          "height"
        ]
      },
      "workflow": "$INPUT_JSON_OBJECT_AS_STRING"
    }
  }
}
