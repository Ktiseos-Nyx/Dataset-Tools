{
  "parser_name": "Standard Image (Non-AI, with EXIF/PNG Chunks)",
  "priority": 10,
  "target_file_types": [
    "PNG",
    "JPEG",
    "WEBP",
    "TIFF"
  ],
  "detection_rules": [
    {
      "comment": "Rule 1: Must be a recognized image format by PIL.",
      "source_type": "file_format",
      "operator": "is_in_list",
      "value_list": [
        "PNG",
        "JPEG",
        "WEBP",
        "TIFF",
        "GIF",
        "BMP"
      ]
    },
    {
      "comment": "Rule 2: AND should NOT have strong AI metadata markers (to avoid claiming a failed AI parse).",
      "condition": "AND",
      "rules": [
        {
          "source_type": "pil_info_key",
          "source_key": "parameters",
          "operator": "not_exists_or_not_ai_string"
        },
        {
          "source_type": "pil_info_key",
          "source_key": "workflow",
          "operator": "not_exists_or_not_ai_json"
        },
        {
          "source_type": "exif_user_comment",
          "operator": "not_exists_or_not_ai_string"
        },
        {
          "source_type": "png_chunk",
          "source_key": "Comment",
          "operator": "not_exists_or_not_ai_json_or_string"
        }
      ]
    }
  ],
  "parsing_instructions": {
    "fields": [
      {
        "target_key": "prompt",
        "method": "static_value",
        "value": null
      },
      {
        "target_key": "negative_prompt",
        "method": "static_value",
        "value": null
      },
      {
        "target_key": "parameters.steps",
        "method": "static_value",
        "value": null
      },
      {
        "target_key": "parameters.tool_specific.software",
        "method": "direct_context_value",
        "source_data_from_context": {
          "type": "pil_info_key",
          "key": "Software"
        },
        "value_type": "string",
        "optional": true
      },
      {
        "target_key": "parameters.tool_specific.gamma",
        "method": "direct_context_value",
        "source_data_from_context": {
          "type": "pil_info_key",
          "key": "gamma"
        },
        "value_type": "float",
        "optional": true
      },
      {
        "target_key": "parameters.tool_specific.dpi_x",
        "method": "direct_context_pil_info_path_transform",
        "pil_info_path": "dpi.0",
        "value_type": "float",
        "optional": true
      },
      {
        "target_key": "parameters.tool_specific.dpi_y",
        "method": "direct_context_pil_info_path_transform",
        "pil_info_path": "dpi.1",
        "value_type": "float",
        "optional": true
      },
      {
        "target_key": "parameters.tool_specific.chromaticity_str",
        "method": "direct_context_value_to_string",
        "source_data_from_context": {
          "type": "pil_info_key",
          "key": "chromaticity"
        },
        "optional": true
      },
      {
        "target_key": "parameters.tool_specific.icc_profile_present",
        "method": "direct_context_boolean_check",
        "context_key_path": "pil_info.icc_profile",
        "optional": true
      },
      {
        "target_key": "parameters.tool_specific.icc_profile_summary",
        "method": "direct_context_icc_profile_summary",
        "optional": true
      }
    ],
    "output_template": {
      "parser_name_from_engine": "Standard Image (Non-AI, with EXIF/PNG Chunks)",
      "tool": "$CONTEXT.pil_info.Software",
      "prompt": "$prompt",
      "negative_prompt": "$negative_prompt",
      "parameters": {
        "width": "$CONTEXT.width",
        "height": "$CONTEXT.height",
        "tool_specific": {
          "image_editor_software": "$parameters.tool_specific.software",
          "gamma": "$parameters.tool_specific.gamma",
          "dpi_x": "$parameters.tool_specific.dpi_x",
          "dpi_y": "$parameters.tool_specific.dpi_y",
          "chromaticity": "$parameters.tool_specific.chromaticity_str",
          "icc_profile_present": "$parameters.tool_specific.icc_profile_present",
          "icc_profile_summary_info": "$parameters.tool_specific.icc_profile_summary"
        }
      },
      "workflow": {
        "pil_info_dict_str_safe": {
          "method": "context_pil_info_to_safe_string_dict"
        }
      }
    }
  }
}
